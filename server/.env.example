PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
MONGO_URI=mongodb://127.0.0.1:27017/bebi_website
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
SPECIAL_ACCESS_CODE=1208
# Prefer ACCESS_CODE_HASH in production. Generate one with bcrypt and remove SPECIAL_ACCESS_CODE.
ACCESS_CODE_HASH=
ARCHIVE_DISPLAY_NAME=Bebi Archive
ADMIN_EMAIL=private@bebi.local
RELATIONSHIP_START_DATE=2024-12-08
SCHEDULER_TIMEZONE=Asia/Singapore
DISABLE_SCHEDULERS=false

# Optional webhook integrations. Leave blank to make notification delivery a safe no-op.
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_EMAIL_TO=
NOTIFICATION_SMS_WEBHOOK_URL=
NOTIFICATION_SMS_TO=
NOTIFICATION_PUSH_WEBHOOK_URL=
